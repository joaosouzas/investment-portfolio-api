# =============================================================================
# INVESTMENT PORTFOLIO API — VARIÁVEIS DE AMBIENTE
# =============================================================================
# Copie este arquivo para .env e preencha com seus valores reais:
#   cp .env.example .env
#
# ATENÇÃO: O arquivo .env NUNCA deve ser commitado no Git.
#          Ele já está no .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# BANCO DE DADOS (PostgreSQL)
# -----------------------------------------------------------------------------
# URL de conexão JDBC com o PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/portfolio_db

# Usuário do banco (deve ter permissão de DDL para o Hibernate criar tabelas)
DB_USERNAME=portfolio_user

# Senha do banco — OBRIGATÓRIA, a aplicação não sobe sem ela
DB_PASSWORD=

# -----------------------------------------------------------------------------
# JWT (JSON Web Token)
# -----------------------------------------------------------------------------
# Chave secreta para assinar os tokens JWT
# Deve ter no mínimo 256 bits (64 caracteres hexadecimais)
#
# Como gerar uma chave segura:
#   Linux/Mac: openssl rand -hex 32
#   Windows PowerShell: [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
#
# NUNCA use a chave de exemplo abaixo em produção.
JWT_SECRET=

# Tempo de expiração do token em milissegundos
# 86400000 = 24 horas | 3600000 = 1 hora | 604800000 = 7 dias
JWT_EXPIRATION=86400000

# -----------------------------------------------------------------------------
# ALPHA VANTAGE (API de cotações em tempo real)
# -----------------------------------------------------------------------------
# Obtenha sua API Key gratuita em:
#   https://www.alphavantage.co/support/#api-key
#
# Plano gratuito: 25 requisições por dia
JWT_SECRET=
ALPHAVANTAGE_KEY=
