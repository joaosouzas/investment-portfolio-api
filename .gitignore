# =============================================================================
# INVESTMENT PORTFOLIO API — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# SEGURANÇA — Nunca commitar estes arquivos
# -----------------------------------------------------------------------------
.env
*.env
!.env.example
*.key
*.pem
*.p12
*.jks

# -----------------------------------------------------------------------------
# MAVEN
# -----------------------------------------------------------------------------
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# -----------------------------------------------------------------------------
# INTELLIJ IDEA
# -----------------------------------------------------------------------------
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# -----------------------------------------------------------------------------
# ECLIPSE
# -----------------------------------------------------------------------------
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# -----------------------------------------------------------------------------
# VS CODE
# -----------------------------------------------------------------------------
.vscode/
*.code-workspace

# -----------------------------------------------------------------------------
# SISTEMA OPERACIONAL
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
*.log
logs/
spring.log

# -----------------------------------------------------------------------------
# RELATÓRIOS DE TESTES E COBERTURA
# -----------------------------------------------------------------------------
/target/site/jacoco/
/target/surefire-reports/

# -----------------------------------------------------------------------------
# DOCKER (volumes locais)
# -----------------------------------------------------------------------------
docker-data/
postgres-data/
